[database]
# The location of the database
url = "database.db"

[server]
# Specifies the folder where downloaded files will go
download_folder = "/tmp/" # MUST end with a '/'

# Authorized tokes
authorization_tokens = ["secret"]

[ui]
private_tags = ["sex", "tantra"]
private_mode = true

[scan]
# If true, will not make changes to the database
dry_run = true

# Map of patterns to automatically place tags using the `apply-tags` command
[scan.auto_tags]
"%Calibre Library%" = ["calibre", "ebook"]

# Define scan options for specific folders.
# Folders with "action" = "Ignore" will not be scanned, even when the parent is explicitly scanned
# Folders with "action" = "Scan" will be scanned when scan is invoked via HTTP
[scan.directories]

[scan.directories."/home/peterpaul/Downloads"]
action = "Ignore"
inherit = false

[scan.directories."/home/peterpaul/Calibre Library"]
action = "Scan"
inherit = true
tags = ["calibre"]
