{
  "name": "read-flow-pwa",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js --config e2e/cucumber.cjs",
    "test:e2e:dev": "tsx ./node_modules/@cucumber/cucumber/bin/cucumber-js --config e2e/cucumber.cjs"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@playwright/test": "^1.60.0",
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.69.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.0.0",
    "playwright": "^1.60.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.13"
  },
  "dependencies": {
    "dexie": "^4.0.8",
    "epubjs": "^0.3.88",
    "fuse.js": "^7.0.0",
    "pdfjs-dist": "^6.1.200"
  }
}
